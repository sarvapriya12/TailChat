# ==========================================                                        
# SUPABASE CONFIGURATION (Database & Auth)                                          
# ==========================================                                        
# 1. Go to https://supabase.com/ and create a new project.                          
# 2. Once the project is created, click the "Settings" (gear icon) on the left sidebar.                                                                              
# 3. Go to "API" under Configuration.                                               
# 4. Copy the "Project URL" into SUPABASE_URL.                                      
SUPABASE_URL=https://your-project-id.supabase.co                                    
                                                                                    
# 5. On the same API settings page, copy the "anon" / "public" Project API key.     
SUPABASE_KEY=your-supabase-anon-key                                                 
                                                                                    
# ==========================================                                        
# GOOGLE OAUTH CONFIGURATION (Sign-In)                                              
# ==========================================                                        
# 1. Go to the Google Cloud Console: https://console.cloud.google.com/              
# 2. Create a new project or select an existing one.                                
# 3. Go to "APIs & Services" -> "Credentials".                                      
# 4. Click "Create Credentials" -> "OAuth client ID".                               
# 5. Set Application type to "Desktop app" (or Web application if loopback is configured as web).                                                                   
# 6. Copy the generated Client ID.                                                  
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com                   
                                                                                    
# ==========================================                                        
# CLOUDFLARE R2 CONFIGURATION (File Storage)                                        
# ==========================================                                        
# 1. Go to your Cloudflare Dashboard -> "R2 Object Storage".                        
# 2. Click "Create bucket" and name it (e.g., tailchat-files).                      
R2_BUCKET_NAME=your-bucket-name                                                     
                                                                                    
# 3. On the R2 dashboard, click "Manage R2 API Tokens" on the right sidebar.        
# 4. Click "Create API token", give it "Object Read & Write" permissions, and create it.                                                                                   
# 5. You will be shown your Access Key ID and Secret Access Key. Copy them below.   
# Note: The Secret Access Key is only shown once!                                   
R2_ACCESS_KEY_ID=your-r2-access-key-id                                              
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key                                      
                                                                                    
# 6. Your Endpoint URL is found on the bucket settings page under "S3 API".         
# It usually looks like: https://<account_id>.r2.cloudflarestorage.com              
R2_ENDPOINT_URL=https://your-cloudflare-account-id.r2.cloudflarestorage.com         
                                                                                    
# 7. To allow public downloads without pre-signed URLs, go to your bucket Settings. 
# 8. Under "Public Access", enable "R2.dev subdomain" or connect a custom domain.   
# 9. Paste that public URL below (e.g., https://pub-xxxxxxxxxx.r2.dev).             
R2_PUBLIC_URL=https://your-public-bucket-url.com   